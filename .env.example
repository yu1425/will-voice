# ============================================================
# うぃる AIボイス - 環境変数サンプル
# ------------------------------------------------------------
# このファイルをコピーして `.env.local` を作成し、値を入れてください。
#
#   cp .env.example .env.local
#
# ※ .env.local は .gitignore 済みなので、キーが公開されることはありません。
# ============================================================

# ============================================================
# VOICEVOX (ローカル ENGINE) — ずんだもんで読み上げたいとき
# ------------------------------------------------------------
# 1. VOICEVOX を https://voicevox.hiroshiba.jp/ からダウンロードして起動
# 2. 既定では ENGINE が http://127.0.0.1:50021 で動きます
# 3. ずんだもんの speaker id は環境/バージョンで変わるため、
#    起動後に  http://localhost:3000/api/voicevox/speakers  または
#    http://127.0.0.1:50021/speakers  にアクセスして確認してください
#    (「ずんだもん」の styles[].id がそれです。例: ノーマル=3)
# ============================================================
VOICEVOX_ENGINE_URL=http://127.0.0.1:50021
VOICEVOX_DEFAULT_SPEAKER_ID=3

# ============================================================
# 将来 AI API に差し替えるとき (今回の無料MVPでは不要)
# ============================================================

# --- Claude API (Anthropic) を使う場合 ---
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# ANTHROPIC_MODEL=claude-opus-4-8

# --- OpenAI API を使う場合 ---
# OPENAI_API_KEY=sk-xxxxxxxx
# OPENAI_MODEL=gpt-4o-mini

# --- 返答生成のプロバイダ切り替え用フラグ(任意) ---
# "mock" | "claude" | "openai"  (未設定なら mock)
# NEXT_PUBLIC_REPLY_PROVIDER=mock
